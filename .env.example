# Telegram
BOT_TOKEN=

# OpenAI-compatible AI backend.
# For OpenAI, set OPENAI_API_KEY and leave AI_BASE_URL empty.
OPENAI_API_KEY=
AI_MODEL=openai/qwen3.6-27b
AI_BASE_URL=

# Example for a custom llama.cpp/OpenAI-compatible endpoint using a
# qwen3.6-27b model with a 256k context configured on the inference side:
# OPENAI_API_KEY=your_endpoint_token
# AI_BASE_URL=https://your-inference.example.com/v1
# AI_MODEL=openai/qwen3.6-27b

# Bot runtime
DAILY_LIMIT=10
MAX_MESSAGES=400
PORT=5000
WEBHOOK_URL=
DATABASE_URL=sqlite:////data/tldrbot.sqlite

# Disabled by default because yt-dlp may need cookies/JS support for some sites.
AUTO_DOWNLOAD_ENABLED=false

# JSON array of regex patterns used only when AUTO_DOWNLOAD_ENABLED=true.
# VIDEO_URL_PATTERNS=["https?://(www\\.)?tiktok\\.com/","https?://(www\\.)?vt\\.tiktok\\.com/","https?://vm\\.tiktok\\.com/","https?://(www\\.)?instagram\\.com/reel/","https?://(www\\.)?youtube\\.com/shorts/","https?://youtu\\.be/"]
