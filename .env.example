# Fill these three values.
BOT_TOKEN=
OPENAI_API_KEY=
AI_BASE_URL=

# Qwen3.6-27B defaults.
AI_MODEL=openai/qwen3.6-27b

# Bot runtime. WEBHOOK_URL is optional; leave it empty to use polling.
DAILY_LIMIT=10
MAX_MESSAGES=400
PORT=5000
WEBHOOK_URL=
DATABASE_URL=sqlite:////data/tldrbot.sqlite

# Token budget for /tldr prompts. When enabled, tokenizer.json is downloaded
# on startup into TOKENIZER_CACHE_DIR. If download/load fails, the bot exits.
TOKEN_LIMIT_ENABLED=true
TOKEN_LIMIT_MAX_INPUT_TOKENS=64000
TOKENIZER_REPO_ID=Qwen/Qwen3.6-27B
TOKENIZER_REVISION=main
TOKENIZER_FILENAME=tokenizer.json
TOKENIZER_CACHE_DIR=/data/tokenizers
TOKENIZER_URL=
HF_TOKEN=

# Disabled by default because yt-dlp may need cookies/JS support for some sites.
AUTO_DOWNLOAD_ENABLED=false

# JSON array of regex patterns used only when AUTO_DOWNLOAD_ENABLED=true.
# VIDEO_URL_PATTERNS=["https?://(www\\.)?tiktok\\.com/","https?://(www\\.)?vt\\.tiktok\\.com/","https?://vm\\.tiktok\\.com/","https?://(www\\.)?instagram\\.com/reel/","https?://(www\\.)?youtube\\.com/shorts/","https?://youtu\\.be/"]
